<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <h2>ADMIN DASHBOARD</h2>

    <p>Welcome, <%= user.name %> — <strong>ADMIN</strong></p>

    <% if (error) { %>
        <p class="error"><%= error %></p>
    <% } %>

    <% if (success) { %>
        <p class="success"><%= success %></p>
    <% } %>

    <h3>Stats</h3>
    <div class="card">
        <p>Total Users: <%= stats.totalUsers %></p>
        <p>Total Bookings: <%= stats.totalBookings %></p>
    </div>

    <h3>All Users</h3>
    <% users.forEach(u => { %>
        <div class="admin-card">
            <p><strong><%= u.name %></strong> — <%= u.email %> — Role: <%= u.role %></p>
            <% if (u.role !== 'admin') { %>
                <form action="/admin/user/delete/<%= u.id %>" method="POST" style="display:inline;">
                    <button type="submit">Delete User</button>
                </form>
            <% } %>
        </div>
    <% }) %>

    <h3>All Bookings</h3>
    <% bookings.forEach(b => { %>
        <div class="admin-card">
            <p>User ID: <%= b.user_id %> — <%= b.date %> — <%= b.time %> — <%= b.service %></p>
            <form action="/admin/booking/delete/<%= b.id %>" method="POST" style="display:inline;">
                <button type="submit">Delete Booking</button>
            </form>
        </div>
    <% }) %>

    <br>
    <a href="/dashboard">User Dashboard</a>
    <a href="/mybookings">My Bookings</a>
    <a href="/logout">Logout</a>

</body>
</html>
