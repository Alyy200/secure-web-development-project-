<!DOCTYPE html>
<html>
<head>
    <title>Edit Booking</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <h2>Edit Booking</h2>

    <% if (error) { %>
        <p class="error"><%= error %></p>
    <% } %>

    <% if (success) { %>
        <p class="success"><%= success %></p>
    <% } %>

    <form action="/booking/update/<%= booking.id %>" method="POST">
        <label>Date:</label><br>
        <input type="date" name="date" value="<%= booking.date.toISOString().split('T')[0] %>" required><br>

        <label>Time:</label><br>
        <input type="time" name="time" value="<%= booking.time %>" required><br>

        <label>Service:</label><br>
        <input type="text" name="service" value="<%= booking.service %>" required><br>

        <button type="submit">Update Booking</button>
    </form>

    <br>
    <a href="/mybookings">⬅ Back to My Bookings</a>

</body>
</html>
