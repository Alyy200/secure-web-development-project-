<!DOCTYPE html>
<html>
<head>
    <title>Edit Booking</title>
    <link rel="stylesheet" href="/style.css">

    <style>
        body {
            background: #000;
            color: #ffd700;
            font-family: Arial, sans-serif;
            text-align: center;
            padding-top: 40px;
        }

        h2 {
            font-size: 32px;
            text-shadow: 0 0 10px #ffd700;
        }

        form {
            display: inline-block;
            background: rgba(255, 215, 0, 0.05);
            padding: 25px;
            border-radius: 10px;
            border: 1px solid #ffd700;
            box-shadow: 0 0 15px #ffd700;
            margin-top: 20px;
        }

        label {
            display: block;
            margin-top: 15px;
            font-size: 18px;
            text-shadow: 0 0 5px #ffd700;
        }

        input {
            width: 250px;
            padding: 10px;
            margin-top: 5px;
            border-radius: 5px;
            border: 1px solid #ffd700;
            background: #111;
            color: #ffd700;
            box-shadow: 0 0 10px #ffd700;
        }

        button {
            margin-top: 20px;
            padding: 12px 25px;
            background: #ffd700;
            color: #000;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            box-shadow: 0 0 15px #ffd700;
            transition: 0.2s;
        }

        button:hover {
            background: #fff;
            box-shadow: 0 0 25px #fff;
        }

        a {
            display: inline-block;
            margin-top: 20px;
            color: #ffd700;
            text-decoration: none;
            font-size: 18px;
            text-shadow: 0 0 10px #ffd700;
        }

        a:hover {
            color: #fff;
        }
    </style>
</head>
<body>

    <h2>Edit Booking</h2>

    <form action="/booking/update/<%= booking.id %>" method="POST">

        <label>Date:</label>
        <input type="date" name="date" value="<%= booking.date.toISOString().split('T')[0] %>" required>

        <label>Time:</label>
        <input type="time" name="time" value="<%= booking.time %>" required>

        <label>Service:</label>
        <input type="text" name="service" value="<%= booking.service %>" required>

        <button type="submit">Update Booking</button>
    </form>

    <br>
    <a href="/mybookings">⬅ Back to My Bookings</a>

</body>
</html>
